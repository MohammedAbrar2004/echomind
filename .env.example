# EchoMind — Environment Variables Template
# Copy this file to .env and fill in your values. Never commit .env.

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=echomind
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# FastAPI Receiver
RECEIVER_HOST=127.0.0.1
RECEIVER_PORT=8000

# Scheduler (pull-based connectors: Gmail, Calendar, etc.)
SCHEDULER_INTERVAL_MINUTES=30

# WhatsApp Baileys service
# WHATSAPP_TARGET_CHATS: JSON array of JIDs to monitor.
#   Individual: "919XXXXXXXXXX@s.whatsapp.net"
#   Group:      "120363XXXXXXXXXXXXXX@g.us"
#   Empty []  : accept all non-group chats (useful for discovering JIDs on first run)
WHATSAPP_TARGET_CHATS=[]
WHATSAPP_POLL_INTERVAL_MINUTES=30
WHATSAPP_SESSION_PATH=./session

# API Keys (future use)
OPENAI_API_KEY=your_openai_api_key_here
WHISPER_API_KEY=your_whisper_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
GMAIL_API_KEY=your_gmail_api_key_here

# Logging
DEBUG=False
LOG_LEVEL=INFO
