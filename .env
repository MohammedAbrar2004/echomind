# EchoMind Environment Variables

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=echomind
DB_USER=postgres
DB_PASSWORD=postgres123

# OpenAI API Key (for embeddings and future LLM features)
OPENAI_API_KEY=your_openai_api_key_here

# Whisper API Key (if using hosted Whisper, otherwise local)
WHISPER_API_KEY=your_whisper_api_key_here

# Other API Keys (placeholders for future integrations)
GOOGLE_API_KEY=your_google_api_key_here
GMAIL_API_KEY=your_gmail_api_key_here

# Backend Configuration
DEBUG=True
LOG_LEVEL=INFO
